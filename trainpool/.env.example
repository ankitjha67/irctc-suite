# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Encryption — MUST be at least 32 random characters. Rotate by re-keying all trips.
TRIP_ENCRYPTION_SECRET=change-me-to-32-plus-random-chars-abc123

# Email
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="TrainPool <hello@trainpool.in>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
